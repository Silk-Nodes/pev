# pev environment configuration
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. Next.js auto-loads it for the app; tsx
# loads it for our scripts (indexer, migrations).
#
# ─── Postgres ─────────────────────────────────────────────────────
# Recommended: a dedicated database `pev` so the indexer's writes
# can't affect other projects sharing the same Postgres instance.
#
DATABASE_URL=postgres://user:password@host:5432/pev

# ─── Monad RPC ────────────────────────────────────────────────────
# HTTP JSON-RPC endpoint (required). Used for eth_getBlockByNumber,
# debug_traceBlockByNumber, eth_blockNumber polling, etc.
MONAD_RPC_URL=https://rpc.silknodes.io/monad

# Optional WebSocket endpoint for real-time `newHeads` subscription.
# Leave blank to fall back to 1s polling (works fine on testnet).
MONAD_WS_URL=

# ─── Indexer tuning ───────────────────────────────────────────────
# Concurrent trace workers (rough rule: 1 per CPU core).
INDEXER_WORKERS=4

# Wait this many blocks behind head before indexing. Protects
# against any unfinalized reorgs (Monad has fast finality but cheap
# insurance). Default: 2.
INDEXER_FINALITY_LAG=2

# When backfilling historical data, start from this block (inclusive).
# Defaults to 100 blocks before current head. Set lower for deep
# backfills.
INDEXER_BACKFILL_FROM=
