out/

# env
# Block every variation of .env files. Only .env.example (the
# committed template) is exempted. Catches .env, .env.local,
# .env.production.local, .env.development.local, .env.*.bak, etc.
.env
.env.*
!.env.example

# Postgres dumps, log files, anything operational
*.dump
*.sql.gz
*.log
deploy/secrets/
deploy/local/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
.DS_Store
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/
.idea/

# claude (local AI working files)
.claude/
